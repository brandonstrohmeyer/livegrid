# Local-only frontend emulator overrides for the dev environment.
# Copy this file to .env.development.local if you want Vite dev mode to use
# Firebase emulators on your machine.
VITE_USE_FIREBASE_EMULATORS=true
VITE_FIREBASE_EMULATOR_AUTH=http://localhost:9099
VITE_FIREBASE_EMULATOR_FIRESTORE=localhost:8080
