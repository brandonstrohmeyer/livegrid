{
  "name": "livegrid",
  "version": "0.2.24",
  "private": true,
  "scripts": {
    "dev": "vite",
    "emulators": "firebase emulators:start --only functions,hosting,firestore,auth --project dev",
    "dev:full": "npx npm-run-all -p --print-label dev emulators",
    "build:firebase-hosting": "node scripts/firebase-hosting-build.mjs",
    "firebase:postdeploy:public-routes": "node scripts/sync-hosting-public-access.mjs",
    "firebase:verify:public-routes": "node scripts/verify-hosting-public-access.mjs",
    "firebase:cleanup:legacy-sheets-env": "node scripts/cleanup-legacy-sheets-env.mjs",
    "firebase:verify:sheets-runtime": "node scripts/verify-sheets-runtime-config.mjs",
    "version:current": "node scripts/build-version.js current",
    "version:ensure": "node scripts/build-version.js ensure",
    "version:bump:patch": "node scripts/build-version.js bump patch",
    "version:bump:minor": "node scripts/build-version.js bump minor",
    "version:bump:major": "node scripts/build-version.js bump major",
    "build": "npm run version:ensure && vite build",
    "build:ci": "npm run version:ensure && vite build",
    "build:patch": "npm run version:bump:patch && vite build",
    "build:minor": "npm run version:bump:minor && vite build",
    "build:major": "npm run version:bump:major && vite build",
    "notifications:backfill-status": "node scripts/backfill-scheduled-notification-status.mjs",
    "notifications:backfill-status:apply": "node scripts/backfill-scheduled-notification-status.mjs --apply",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:integration:inner": "vitest run --config vitest.integration.config.mjs",
    "test:integration": "cross-env LIVEGRID_TEST_MODE=true LIVEGRID_TEST_MESSAGING=stub LIVEGRID_TEST_FIXTURES_DIR=functions/test-fixtures GCLOUD_PROJECT=livegrid-c33c6 FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 firebase emulators:exec --project prod --only functions,firestore,hosting,auth \"npm run test:integration:inner\"",
    "test:e2e:inner": "playwright test",
    "test:e2e": "cross-env VITE_USE_FIREBASE_EMULATORS=true VITE_FIREBASE_PROJECT_ID=livegrid-c33c6 VITE_FUNCTIONS_BASE_URL=http://localhost:5001/livegrid-c33c6/us-central1 VITE_FIREBASE_EMULATOR_AUTH=http://localhost:9099 VITE_FIREBASE_EMULATOR_FIRESTORE=localhost:8080 firebase emulators:exec --project prod --only functions,firestore,auth \"npm run test:e2e:inner\"",
    "test:build": "npm run build:ci && npm --prefix functions run build",
    "test:predeploy": "npm run test:run && npm run test:build && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "fast-xml-parser": "^5.3.3",
    "firebase": "^11.0.1",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-pro-sidebar": "^1.1.0",
    "viewportify": "^1.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.0.0",
    "cross-env": "^7.0.3",
    "firebase-admin": "^11.11.1",
    "firebase-functions-test": "^3.1.1",
    "jsdom": "^27.4.0",
    "msw": "^2.7.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17"
  }
}
